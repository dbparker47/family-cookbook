<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="curry" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Red Dwarf Chicken Curry</title>

  <p>
    Ingredients:
  </p>
  <tabular>
    <row>
      <cell><m>1 \frac{1}{2}</m> cups rice</cell>
    </row>
    <row>
      <cell>1 teaspoon turmeric</cell>
    </row>
    <row>
      <cell><m>1 \frac{1}{2}</m> pounds chicken, cut into thin strips</cell>
    </row>
    <row>
    <cell>1 onion, finely sliced</cell>
    </row>
    <row>
      <cell>1 tablespoon canola oil</cell>
    </row>
    <row>
      <cell>1 teaspoon curry paste</cell>
    </row>
    <row>
      <cell>2-3 cloves garlic, minced</cell>
    </row>
    <row>
      <cell>4 ounces chicken broth (1 tablespoon "Better than Boullion")</cell>
    </row>
    <row>
      <cell>1 can coconut milk</cell>
    </row>
    <row>
      <cell>1/2 - 1 teaspoon cayenne pepper</cell>
    </row>
    <row>
      <cell>2-3 tablespoons mango chutney (or peach jam)</cell>
    </row>
  </tabular>

  <p>Instructions
    <ul>
      <li>
        <p>
          Cook rice with turmeric.
        </p>
      </li>
      <li>
        <p>
          Add onion and chicken to canola oil and brown.
        </p>
      </li>
      <li>
        <p>
          Add curry paste, garlic, broth, and coconut milk.  Cook until slightly thickened.
        </p>
      </li>
      <li>
        <p>
          Add chutney just before serving.
        </p>
      </li>
    </ul>
  </p>

  <p>
    Notes:
    <ul>
      <li>
        <p>
          
        </p>
      </li>
    </ul>
  </p>
</section>