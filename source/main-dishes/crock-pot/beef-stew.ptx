<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="b-stew" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Beef Stew</title>

  <p>
    Ingredients:
  </p>
  <tabular>
    <row>
      <cell>2+ lb English roast or chuck roast</cell>
    </row>
    <row>
      <cell>2 tablespoons Worcestershire sauce</cell>
    </row>
    <row>
      <cell><m>\frac{1}{4}</m> to <m>\frac{1}{2}</m> cup flour</cell>
    </row>
    <row>
    <cell>1 teaspoon paprika</cell>
    </row>
    <row>
      <cell><m>1 \frac{1}{2}</m> cups beef or vegetable broth</cell>
    </row>
    <row>
      <cell>1 garlic clove, minced</cell>
    </row>
    <row>
      <cell>1 bay leaf</cell>
    </row>
    <row>
      <cell>4 to 8 carrots, sliced (there cannot be too many carrots)</cell>
    </row>
    <row>
      <cell>1 large onion</cell>
    </row>
    <row>
      <cell>1 to 3 ribs of celery, sliced</cell>
    </row>
    <row>
      <cell>3 potatoes, diced</cell>
    </row>
  </tabular>

  <p>Instructions
    <ol>
      <li>
        <p>
          Place meat in the crockpot.
        </p>
      </li>
      <li>
        <p>
          Combine flour and paprika, and stir into meat until the meat is coated thoroughly.
        </p>
      </li>
      <li>
        <p>
          Add remaining ingredients and mix well.
        </p>
      </li>
      <li>
        <p>
          Cover and cook on low for 10 to 12 hours.
        </p>
      </li>
    </ol>
  </p>

  <p>
    Notes:
    <ul>
      <li>
        <p>
          
        </p>
      </li>
    </ul>
  </p>
</section>