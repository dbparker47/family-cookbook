<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="ter-pulled-pork" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Teryaki Pulled Pork</title>

  <p>
    Ingredients:
  </p>
  <tabular>
    <row>
      <cell>3 to 4 pounds boneless pork shoulder</cell>
    </row>
    <row>
      <cell>1 cup brown sugar, packed</cell>
    </row>
    <row>
      <cell><m>\frac{1}{3}</m> cup unsweetened apple juice</cell>
    </row>
    <row>
    <cell><m>\frac{1}{3}</m> cup soy sauce</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> teaspoon salt (optional)</cell>
    </row>
    <row>
      <cell><m>\frac{1}{4}</m> teaspoon pepper (optional)</cell>
    </row>
    <row>
      <cell>2 tablespoons cornstarch</cell>
    </row>
    <row>
      <cell>3 tablespoons cold water</cell>
    </row>
  </tabular>

  <p>Instructions
    <ol>
      <li>
        <p>
          Cut roast in half and rub with brown sugar.  Place in crock pot.  Pour apple juice and soy sauce over the roast.
        </p>
      </li>
      <li>
        <p>
          Cover and cook on low for 6 to <m>6 \frac{1}{2}</m> hours or until meat is tender.
        </p>
      </li>
      <li>
        <p>
          Remove roast; cover and let stand for 15 minutes, straining juices.  Return everything to the crockpot.
        </p>
      </li>
      <li>
        <p>
          Combine cornstarch and cold water until smooth, and gradually stir it into the juices.
        </p>
      </li>
      <li>
        <p>
          Cover and cook on high for 15 minutes, or until thickened.
        </p>
      </li>
    </ol>
  </p>

  <p>
    Notes:
    <ul>
      <li>
        <p>
          
        </p>
      </li>
    </ul>
  </p>
</section>