<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="cash-sauce" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Cashew Sauce</title>

  <p>
    Ingredients
  </p>
  <tabular>
    <row>
      <cell>2 cups toasted cashews</cell>
    </row>
    <row>
      <cell>1 cup water</cell>
    </row>
    <row>
      <cell>2 tablespoons minced fresh ginger</cell>
    </row>
    <row>
    <cell>1 tablespoon soy sauce</cell>
    </row>
    <row>
      <cell>1 tablespoon honey or sugar (brown or white)</cell>
    </row>
    <row>
      <cell>2 tablespoons plus 1 teaspoon apple cider vinegar</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> teaspoon salt</cell>
    </row>
    <row>
      <cell>cayenne, to taste</cell>
    </row>
  </tabular>

  <p>Instructions
    <ol>
      <li>
        <p>
          Puree everything together in a food processor or a blender until it is as smooth as you'd like.  Gently heat before serving.
        </p>
      </li>
    </ol>
  </p>

  <p>
    Notes:
    <ul>
      <li>
        <p>
          Used in <alert>Meatless Loaf</alert>.
        </p>
      </li>
    </ul>
  </p>
</section>