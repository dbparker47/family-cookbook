<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="artichoke-casserole" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Artichoke Casserole (Grandmommy Hamo)</title>

  <p>
    Ingredients:
  </p>
  <tabular>
    <row>
      <cell>6 tablespoons unsalted butter, melted</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> cup bread crumbs</cell>
    </row>
    <row>
      <cell>2 onions, finely chopped</cell>
    </row>
    <row>
    <cell>9 eggs, separated</cell>
    </row>
    <row>
      <cell>30 ounces artichoke hearts</cell>
    </row>
    <row>
      <cell><m>\frac{1}{4}</m> teaspoon cayenne</cell>
    </row>
    <row>
      <cell>1 pound sharp cheddar cheese</cell>
    </row>
    <row>
      <cell>2 tablespoons fresh parsley, chopped</cell>
    </row>
  </tabular>

  <p>Instructions
    <ol>
      <li>
        <p>
          Mix 2 tablespoons of the butter with the bread crumbs
        </p>
      </li>
      <li>
        <p>
          Cook onions with the remaining butter.
        </p>
      </li>
      <li>
        <p>
          Beat egg whites until fluffy, and beat yolks until foamy.
        </p>
      </li>
      <li>
        <p>
          Mix everything in a large bowl., and pour ungreased into a 9'' x 13'' x 2'' baking dish.  Store overnight.
        </p>
      </li>
      <li>
        <p>
          Top with bread crumbs, and bake at 350 degrees for 35-40 minutes.
        </p>
      </li>
    </ol>
  </p>

  <p>
    Notes:
    <ul>
      <li>
        <p>
          
        </p>
      </li>
    </ul>
  </p>
</section>