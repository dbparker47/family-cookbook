<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="sausage-cass" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Sausage Breakfast Casserole (Grandmommy Hamo)</title>

  <p>
    Ingredients:
  </p>
  <tabular>
    <row>
      <cell>5 slices firm bread, cubed</cell>
    </row>
    <row>
      <cell>1 pound sausage</cell>
    </row>
    <row>
      <cell><m>1 \frac{1}{2}</m> cup grated cheese</cell>
    </row>
    <row>
    <cell>9 eggs, beaten</cell>
    </row>
    <row>
      <cell>2 cups milk or half-and-half</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> teaspoon salt (optional)</cell>
    </row>
    <row>
      <cell>1 teaspoon dry mustard</cell>
    </row>
  </tabular>

  <p>Instructions
    <ol>
      <li>
        <p>
          Place half of the bread into a greased 9'' x 13'' baking dish.
        </p>
      </li>
      <li>
        <p>
          Sprinkle in cheese, sausage, and the rest of the bread.
        </p>
      </li>
      <li>
        <p>
          Pour the mixture of the eggs, milk, salt, and mustard into the baking dish.
        </p>
      </li>
      <li>
        <p>
          Bake at <m>350\circ</m> for 45 minutes.
        </p>
      </li>
    </ol>
  </p>

  <p>
    Notes:
    <ul>
      <li>
        <p>
          
        </p>
      </li>
    </ul>
  </p>
</section>