<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="quiche-cb" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Cheese and Bacon Quiche</title>

  <p>
    Ingredients:
  </p>
  <tabular>
    <row>
      <cell><xref ref="reg-crust">Regular Pie Crust (1/2 recipe)</xref></cell>
    </row>
    <row>
      <cell><m>\frac{1}{4}</m> cup butter (softened)</cell>
    </row>
    <row>
      <cell>4 eggs</cell>
    </row>
    <row>
    <cell>2 cups heavy cream</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> teaspoon salt</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> cup grated Swiss cheese</cell>
    </row>
    <row>
      <cell>1 tablespoon butter</cell>
    </row>
    <row>
      <cell><m>\frac{3}{4}</m> cup chopped cooked bacon (12 ounces, uncooked)</cell>
    </row>
    <row>
      <cell>2 tablespoons minced green onions</cell>
    </row>
    <row>
      <cell><m>\frac{1}{8}</m> of pepper</cell>
    </row>
    <row>
      <cell>Dab of stinky cheese (Stilton or Camembert will work)</cell>
    </row>
  </tabular>

  <p>Instructions
    <ol>
      <li>
        <p>
          Preheat oven to <m>425^\circ</m>.
        </p>
      </li>
      <li>
        <p>
          In a large bowl, beat eggs, heavy cream, and salt with a whisk.  Stir in the grated cheese.
        </p>
      </li>
      <li>
        <p>
          Melt the tablespoon of butter in a skillet over medium-high heat.
        </p>
      </li>
      <li>
        <p>
          Add the chopped bacon, minced green onions, and pinch of pepper.  Cook for 5 minutes or until the onions are tender, stirring frequently.
        </p>
      </li>
      <li>
        <p>
          Stir the bacon and onion mixture into the cream mixture.
        </p>
      </li>
      <li>
        <p>
          Pour into pie and bake for 15 minutes at <m>425^\circ</m>.
        </p>
      </li>
      <li>
        <p>
          Reduce heat to <m>325^\circ</m> and bake for another 35 minutes.
        </p>
      </li>
      <li>
        <p>
          Allow to stand for 10 to 15 minutes.
        </p>
      </li>
      <li>
        <p>
          Spoon a dab of soft stinky chess on top before serving piping hot.
        </p>
      </li>
    </ol>
  </p>

  <p>
    Notes:
    <ul>
      <li>
        <p>
          
        </p>
      </li>
    </ul>
  </p>
</section>