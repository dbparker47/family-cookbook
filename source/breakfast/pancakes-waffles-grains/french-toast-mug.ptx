<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="f-toast-mug" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>French Toast (Mug)</title>

  <p>
    Ingredients:
  </p>
  <tabular>
    <row>
      <cell>2 slices bread, cubed</cell>
    </row>
    <row>
      <cell>Raspberries</cell>
    </row>
    <row>
      <cell>1 egg, beaten</cell>
    </row>
    <row>
    <cell><m>\frac{1}{3}</m> cup milk</cell>
    </row>
    <row>
      <cell>1 tablespoon cocoa powder</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> teaspoon cinnamon</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> vanilla extract</cell>
    </row>
  </tabular>

  <p>Instructions
    <ol>
      <li>
        <p>
          Place half the bread in a 16-oz mug.  Layer in half the raspberries, the rest of the break, and the rest of the raspberries.
        </p>
      </li>
      <li>
        <p>
          Separately, whisk together egg, mild, cocoa powder, cinnamon, and vanilla extract.  Pour mixture into mug and let sit 1 minute.
        </p>
      </li>
      <li>
        <p>
          Microwave for about 2 minutes.  Top with maple syrup and nuts.
        </p>
      </li>
    </ol>
  </p>

  <p>
    Notes:
    <ul>
      <li>
        <p>
          
        </p>
      </li>
    </ul>
  </p>
</section>