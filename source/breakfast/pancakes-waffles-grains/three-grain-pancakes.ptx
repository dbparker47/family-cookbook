<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="three-grain-cakes" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Three-grain Pancakes</title>

  <p>
    Ingredients:
  </p>
  <tabular>
    <row>
      <cell><m>1 \frac{3}{4}</m> cup whole-wheat flour</cell>
    </row>
    <row>
      <cell><m>\frac{1}{3}</m> cup cornmeal</cell>
    </row>
    <row>
      <cell><m>\frac{1}{3}</m> cup rolled oats</cell>
    </row>
    <row>
    <cell>2 teaspoons baking powder</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> teaspoon salt</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> teaspoon baking soda</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> teaspoon cinnamon</cell>
    </row>
    <row>
      <cell><m>\frac{1}{8}</m> teaspoon nutmeg</cell>
    </row>
    <row>
      <cell><m>1 \frac{3}{4}</m> cup milk</cell>
    </row>
    <row>
      <cell>4 tablespoons butter, melted</cell>
    </row>
    <row>
      <cell><m>\frac{1}{4}</m> cup honey</cell>
    </row>
    <row>
      <cell>3 extra-large eggs</cell>
    </row>
    <row>
      <cell>1 teaspoon vanilla extract</cell>
    </row>
    <row>
      <cell>Chocolate chips, bananas, blueberries, or other creative mix-ins (optional)</cell>
    </row>
  </tabular>

  <p>Instructions
    <ol>
      <li>
        <p>
          Mix dry ingredients together.
        </p>
      </li>
      <li>
        <p>
          Mix wet ingredients together.
        </p>
      </li>
      <li>
        <p>
          Pour wet ingredients into dry ingredients. Mix until just combined.
        </p>
      </li>
      <li>
        <p>
          Cook on the griddle with mix-ins. 
        </p>
      </li>
    </ol>
  </p>

  <p>
    Notes:
    <ul>
      <li>
        <p>
          I have made these with blueberries, sliced bananas, and chocolate chips.  I add the mix-ins to the batter right after I put it on the griddle and cover it with batter so it doesn't burn when I flip the pancakes.
        </p>
      </li>
    </ul>
  </p>
</section>