<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="bub-bread" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Bubble Bread (Grandma Joy)</title>

  <p>
    Ingredients:
  </p>
  <tabular>
    <row>
      <cell><term>Dough:</term></cell>
    </row>
    <row>
      <cell><m>\frac{2}{3}</m> cup sugar</cell>
    </row>
    <row>
      <cell>1 teaspoon cinnamon</cell>
    </row>
    <row>
    <cell>4 tubes of biscuits (32 oz total)</cell>
    </row>
    <row>
      <cell><term>Glaze:</term></cell>
    </row>
    <row>
      <cell>12 tablespoons (<m>1 \frac{1}{2}</m> sticks) butter, melted</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> cup sugar</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> cup brown sugar</cell>
    </row>
    <row>
      <cell>1 teaspoon cinnamon</cell>
    </row>
  </tabular>

  <p>Instructions
    <ol>
      <li>
        <p>
          Cut biscuit tubes in fourths with pizza cutter or shears.
        </p>
      </li>
      <li>
        <p>
          Mix cinnamon and sugar; roll biscuits in cinnamon/sugar mixture.
        </p>
      </li>
      <li>
        <p>
          Layer biscuit pieces in a Bundt pan or angel food cake pan.
        </p>
      </li>
      <li>
        <p>
          Mix glaze ingredients together and pour over biscuits.
        </p>
      </li>
      <li>
        <p>
          Bake at <m>350^\circ</m> for 35 minutes.
        </p>
      </li>
    </ol>
  </p>

  <p>
    Notes:
    <ul>
      <li>
        <p>
          Keep an eye on the total amount of biscuits.  I use the larger tubes of biscuits (16 ounces each), so I only use two tubes.
        </p>
      </li>
    </ul>
  </p>
</section>