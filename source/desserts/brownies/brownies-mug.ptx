<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="mug-brown" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Mug Brownie</title>

  <p>
    Ingredients:
  </p>
  <tabular>
    <row>
      <cell>4 tablespoons flour</cell>
    </row>
    <row>
      <cell>4 tablespoons sugar</cell>
    </row>
    <row>
      <cell>2 tablespoons cocoa</cell>
    </row>
    <row>
    <cell>2 tablespoons canola oil</cell>
    </row>
    <row>
      <cell>2 tablespoons water</cell>
    </row>
  </tabular>

  <p>Instructions
    <ol>
      <li>
        <p>
          Mix ingredients in a mug.
        </p>
      </li>
      <li>
        <p>
          Microwave for 50 seconds.
        </p>
      </li>
    </ol>
  </p>

  <p>
    Notes:
    <ul>
      <li>
        <p>
          
        </p>
      </li>
    </ul>
  </p>
</section>