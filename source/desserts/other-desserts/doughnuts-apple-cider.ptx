<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="dough-apple-cider" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Doughnuts - Apple Cider</title>

  <p>
    Ingredients:
  </p>
  <tabular>
    <row>
      <cell><term>Doughnuts:</term></cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> cup apple cider</cell>
    </row>
    <row>
      <cell><m>1 \frac{3}{4}</m> cups flour</cell>
    </row>
    <row>
    <cell><m>\frac{1}{2}</m> cup white sugar</cell>
    </row>
    <row>
      <cell>1 teaspoon baking powder</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> teaspoon baking soda</cell>
    </row>
    <row>
      <cell><m>\frac{1}{8}</m> teaspoon salt</cell>
    </row>
    <row>
      <cell><m>\frac{1}{4}</m> teaspoon cinnamon</cell>
    </row>
    <row>
      <cell><m>\frac{1}{8}</m> teaspoon nutmeg</cell>
    </row>
    <row>
      <cell><m>\frac{1}{4}</m> cup buttermilk</cell>
    </row>
    <row>
      <cell>2 tablespoons butter, melted</cell>
    </row>
    <row>
      <cell>1 egg, lightly beaten</cell>
    </row>
    <row>
      <cell><term>Glaze:</term></cell>
    </row>
    <row>
      <cell><m>\frac{1}{3}</m> cup confectioner's sugar</cell>
    </row>
    <row>
      <cell>1 tablespoon cider</cell>
    </row>
  </tabular>

  <p>Instructions
    <ol>
      <li>
        <p>
          Place cider in a small saucepan on stove set to medium-high and reduce to 2 tablespoons; cool completely.
        </p>
      </li>
      <li>
        <p>
          Combine all dry ingredients, except sugar, in one mixing bowl; combine all wet ingredients, plus sugar, in another mixing bowl.
        </p>
      </li>
      <li>
        <p>
          Pour wet ingredients into dry ingredients; mix until just fully incorporated.
        </p>
      </li>
      <li>
        <p>
          Cook in doughnut maker.
        </p>
      </li>
      <li>
        <p>
          Whisk together confectioner's sugar and cider; brush doughnut tops with glaze.
        </p>
      </li>
    </ol>
  </p>

  <p>
    Notes:
    <ul>
      <li>
        <p>
          
        </p>
      </li>
    </ul>
  </p>
</section>