<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="straw-rhub-crisp" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Strawberry-Rhubarb Crisp</title>

  <p>
    Ingredients:
  </p>
  <tabular>
    <row>
      <cell>2 pounds fresh rhubarb, cut into 1-inch chunks</cell>
    </row>
    <row>
      <cell>3 to 4 cups sliced strawberries</cell>
    </row>
    <row>
      <cell><m>\frac{1}{3}</m> to <m>\frac{1}{2}</m> cup white sugar</cell>
    </row>
    <row>
    <cell>1 cup rolled oats</cell>
    </row>
    <row>
      <cell>1 cup flour</cell>
    </row>
    <row>
      <cell>2 to 3 tablespoons brown sugar</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> teaspoon cinnamon</cell>
    </row>
    <row>
      <cell>A dash or two each of allspice and nutmeg</cell>
    </row>
    <row>
      <cell><m>\frac{1}{4}</m> teaspoon salt</cell>
    </row>
    <row>
      <cell>5 tablespoons melted butter</cell>
    </row>
  </tabular>

  <p>Instructions
    <ol>
      <li>
        <p>
          Combine rhubarb and strawberries in a 9" x 9" pan.  Sprinkle with white sugar.
        </p>
      </li>
      <li>
        <p>
          Mix together the remaining ingredients in a medium-sized bowl.  Distribute over the top of the fruit and pat firmly into place.
        </p>
      </li>
      <li>
        <p>
          Bake uncovered for 35-40 minutes at <m>375^\circ</m> or until the top is crisp and lightly browned and the fruit is bubbling around the edges.  Serve hot, warm, or at room temperature, plain or a la mode.
        </p>
      </li>
    </ol>
  </p>

  <p>
    Notes:
    <ul>
      <li>
        <p>
          
        </p>
      </li>
    </ul>
  </p>
</section>