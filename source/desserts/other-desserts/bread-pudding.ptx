<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="bread-pudd" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Bread Pudding</title>

  <p>
    Ingredients:
  </p>
  <tabular>
    <row>
      <cell>4 packed cups of cubed bread</cell>
    </row>
    <row>
      <cell>3 eggs</cell>
    </row>
    <row>
      <cell>3 cups milk</cell>
    </row>
    <row>
    <cell><m>\frac{1}{2}</m> cup sugar</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> teaspoon salt</cell>
    </row>
    <row>
      <cell>2 teaspoons vanilla</cell>
    </row>
    <row>
      <cell>1 cup chocolate chips (optional)</cell>
    </row>
  </tabular>

  <p>Instructions
    <ol>
      <li>
        <p>
          Spread bread in 9" x 13" baking pan.
        </p>
      </li>
      <li>
        <p>
          Beat together remaining ingredients.  Pour over bread.
        </p>
      </li>
      <li>
        <p>
          Bake at <m>350^\circ</m> until firm but not dry (35 minutes).
        </p>
      </li>
    </ol>
  </p>

  <p>
    Notes:
    <ul>
      <li>
        <p>
          
        </p>
      </li>
    </ul>
  </p>
</section>