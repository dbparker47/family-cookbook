<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="dough-basic" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Doughnuts - Basic</title>

  <p>
    Ingredients:
  </p>
  <tabular>
    <row>
      <cell><m>1 \frac{1}{2}</m> cups flour</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> cup sugar</cell>
    </row>
    <row>
      <cell><m>1 \frac{1}{2}</m> teaspoons baking powder</cell>
    </row>
    <row>
    <cell>9 tablespoons butter, melted</cell>
    </row>
    <row>
      <cell><m>\frac{3}{4}</m> cup milk</cell>
    </row>
    <row>
      <cell>1 egg, lightly beaten</cell>
    </row>
  </tabular>

  <p>Instructions
    <ol>
      <li>
        <p>
          Combine all dry ingredients in one mixing bowl; combine all wet ingredients in another mixing bowl.
        </p>
      </li>
      <li>
        <p>
          Pour wet ingredients into dry ingredients; mix until batter is smooth.
        </p>
      </li>
      <li>
        <p>
          Cook in doughnut maker.
        </p>
      </li>
    </ol>
  </p>

  <p>
    Notes:
    <ul>
      <li>
        <p>
          
        </p>
      </li>
    </ul>
  </p>
</section>