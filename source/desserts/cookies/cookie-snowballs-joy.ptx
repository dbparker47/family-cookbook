<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="snowball" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Snowballs (Grandma Joy)</title>

  <p>
    Ingredients:
  </p>
  <tabular>
    <row>
      <cell>1 lb. butter</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> cup white sugar</cell>
    </row>
    <row>
      <cell>4 cups flour (add <m>\frac{1}{2}</m> cup flour for no nuts)</cell>
    </row>
    <row>
    <cell>2 cups walnuts</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> teaspoon salt</cell>
    </row>
    <row>
      <cell>2 teaspoons vanilla</cell>
    </row>
    <row>
      <cell>Confectioners' sugar</cell>
    </row>
  </tabular>

  <p>Instructions
    <ol>
      <li>
        <p>
          Melt butter on stove; let it cool a little.
        </p>
      </li>
      <li>
        <p>
          Add flour, salt, and sugar; mix well.
        </p>
      </li>
      <li>
        <p>
          Stir in nuts and vanilla, and roll into balls.
        </p>
      </li>
      <li>
        <p>
          Place on cookie sheet; bake at <m>400^\circ</m> for 10-15 minutes.  Snowballs should be slightly browned on the edges.
        </p>
      </li>
      <li>
        <p>
          Let them cool a little; roll in powdered sugar.
        </p>
      </li>
    </ol>
  </p>

  <p>
    Notes:
    <ul>
      <li>
        <p>
          
        </p>
      </li>
    </ul>
  </p>
</section>