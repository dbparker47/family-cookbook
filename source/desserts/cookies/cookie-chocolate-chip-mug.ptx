<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="choc-chip-mug" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Chocolate Chip Cookie (Mug)</title>

  <p>
    Ingredients:
  </p>
  <tabular>
    <row>
      <cell>1 tablespoon butter</cell>
    </row>
    <row>
      <cell>Pinch of salt</cell>
    </row>
    <row>
      <cell>1 tablespoon each brown/white sugar</cell>
    </row>
    <row>
    <cell>1 egg</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> teaspoons vanilla</cell>
    </row>
    <row>
      <cell>2 heaping tablespoons flour</cell>
    </row>
    <row>
      <cell>1 tablespoon chocolate chips</cell>
    </row>
  </tabular>

  <p>Instructions
    <ol>
      <li>
        <p>
          Melt butter.  Add sugar, vanilla, and egg.  Mix together.  Add flour and stir.  Add chocolate chips and stir.
        </p>
      </li>
      <li>
        <p>
          Microwave for 50 seconds on half power (one cookie).
        </p>
      </li>
    </ol>
  </p>

  <p>
    Notes:
    <ul>
      <li>
        <p>
          
        </p>
      </li>
    </ul>
  </p>
</section>