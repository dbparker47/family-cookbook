<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="nanaimo" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Nanaimo Bars </title>

  <p>
    Ingredients:
  </p>
  <tabular>
    <row>
      <cell>1 cup butter, softened, divided</cell>
    </row>
    <row>
      <cell>5 tablespoons unsweetened cocoa powder</cell>
    </row>
    <row>
      <cell><m>\frac{1}{4}</m> cup white sugar</cell>
    </row>
    <row>
    <cell>1 large egg, beaten</cell>
    </row>
    <row>
      <cell><m>1 \frac{3}{4}</m> cups graham cracker crumbs (12 sheets)</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> cup finely chopped almonds (Optional)</cell>
    </row>
    <row>
      <cell>3 tablespoons heavy cream or whole milk</cell>
    </row>
    <row>
      <cell>2 tablespoons custard powder</cell>
    </row>
    <row>
      <cell>2 cups confectioners' sugar</cell>
    </row>
    <row>
      <cell>6 squares semisweet baking chocolate (1.5 ounce)</cell>
    </row>
    <row>
      <cell>2 tablespoons butter</cell>
    </row>
  </tabular>

