<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="choc-p-butter-bar" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Chocolate Peanut Butter Bars</title>

  <p>
    Ingredients:
  </p>
  <tabular>
    <row>
      <cell>2 cups graham cracker crumbs (14 graham cracker sheets)</cell>
    </row>
    <row>
      <cell>2 cups confectioners' sugar</cell>
    </row>
    <row>
      <cell>1 cup butter, melted</cell>
    </row>
    <row>
    <cell>1 cup peanut butter</cell>
    </row>
    <row>
      <cell><m>1 \frac{1}{2}</m> cups semisweet chocolate chips</cell>
    </row>
    <row>
      <cell>4 tablespoons (1/4 cup) peanut butter</cell>
    </row>
  </tabular>

  <p>Instructions
    <ol>
      <li>
        <p>
          Mix together graham cracker crumbs, confectioners' sugar, butter, and 1 cup peanut butter in a medium bowl until well-blended. Press evenly into the bottom of an ungreased 9" x 13" pan. Place pan in refrigerator.
        </p>
      </li>
      <li>
        <p>
          Microwave chocolate chips at half power until completely melted, stopping every 30-60 seconds to stir. Stir in remaining peanut butter.
        </p>
      </li>
      <li>
        <p>
          Spread chocolate mixture over peanut butter mixture. Refrigerate for about 45 minutes before cutting into 18 squares. Store in air-tight container in refrigerator.
        </p>
      </li>
    </ol>
  </p>

  <p>
    Notes:
    <ul>
      <li>
        <p>
          
        </p>
      </li>
    </ul>
  </p>
</section>