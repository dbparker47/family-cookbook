<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="pump-pie" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Squash Pie</title>

  <p>
    Ingredients:
  </p>
  <tabular>
    <row>
      <cell>1 large <alert>baked butternut squash</alert> (or 29 ounce can of pumpkin)</cell>
    </row>
    <row>
      <cell>Half-recipe of <alert>Regular Pie Crust</alert></cell>
    </row>
    <row>
      <cell>3 eggs</cell>
    </row>
    <row>
    <cell><m>1 \frac{1}{2}</m> cups coconut milk, heavy cream, or evaporated milk</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> cup sugar</cell>
    </row>
    <row>
      <cell><m>\frac{1}{3}</m> cup packed brown sugar</cell>
    </row>
    <row>
      <cell>1 teaspoon cinnamon</cell>
    </row>
    <row>
      <cell>1 teaspoon ground or grated fresh ginger</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> teaspoon nutmeg</cell>
    </row>
    <row>
      <cell><m>\frac{1}{8}</m> teaspoon ground cloves or allspice</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> teaspoon salt</cell>
    </row>
  </tabular>

  <p>Instructions
    <ol>
      <li>
        <p>
          Mix together filling ingredients (i.e. everything from the eggs to the salt).
        </p>
      </li>
      <li>
        <p>
          Pour filling into crust.
        </p>
      </li>
      <li>
        <p>
          Bake at <m>400\circ</m> for 75 minutes, or until center of pie barely jiggles when you shake it.
        </p>
      </li>
    </ol>
  </p>

  <p>
    Notes:
    <ul>
      <li>
        <p>
          Don't put in too much cloves.  They can be overpowering.
        </p>
      </li>
    </ul>
  </p>
</section>