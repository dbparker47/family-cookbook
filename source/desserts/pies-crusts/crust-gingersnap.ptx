<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="ginger-crust" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Gingersnap Pie Crust (Grandma Janet)</title>

  <p>
    Ingredients:
  </p>
  <tabular>
    <row>
      <cell><m>1 \frac{1}{4}</m> cups gingersnap crumbs, finely crushed</cell>
    </row>
    <row>
      <cell><m>\frac{1}{4}</m> cup butter, melted</cell>
    </row>
  </tabular>

  <p>Instructions
    <ol>
      <li>
        <p>
          Thoroughly blend the gingersnap crumbs and melted butter. 
        </p>
      </li>
      <li>
        <p>
          Press on bottom and sides of 9-in pie pan with back of tablespoon.
        </p>
      </li>
      <li>
        <p>
          Bake at <m>350^\circ</m> for 10 minutes.
        </p>
      </li>
    </ol>
  </p>

  <p>
    Notes:
    <ul>
      <li>
        <p>
          Do not over brown.
        </p>
      </li>
      <li>
        <p>
          Cool before filling.
        </p>
      </li>
      <li>
        <p>
          This crust is used in <xref ref="pie-black-bot">Black Bottom Pie</xref>.
        </p>
      </li>
    </ul>
  </p>
</section>