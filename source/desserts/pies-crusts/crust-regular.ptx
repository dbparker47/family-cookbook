<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="reg-crust" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Pie Crust (Regular)</title>

  <p>
    Ingredients:
  </p>
  <tabular>
    <row>
      <cell><m>\frac{2}{3}</m> cup canola oil</cell>
    </row>
    <row>
      <cell>2 cups all-purpose flour</cell>
    </row>
    <row>
      <cell><m>\frac{1}{3}</m> cup water</cell>
    </row>
  </tabular>

  <p>Instructions
    <ol>
      <li>
        <p>
          Mix oil and water briskly.
        </p>
      </li>
      <li>
        <p>
          Dump oil-water mixture on flour and mix vigorously with fork.  Bring crust together with hands.  Pray for good luck.
        </p>
      </li>
      <li>
        <p>
          If you need to blind bake it, bake crust 8-10 minutes at 475 degrees.
        </p>
      </li>
    </ol>
  </p>

  <p>
    Notes:
    <ul>
      <li>
        <p>
          This crust is used in <xref ref="quiche-cb">Cheese and Bacon Quiche</xref>, Apple Pie, Blueberry Pie, Rhubarb Pie, Squash Pie, Sweet Potato Pie
        </p>
      </li>
    </ul>
  </p>
</section>