<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="rhubarb-upside-down" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Rhubarb Upside-Down Cake</title>

  <p>
    Ingredients:
  </p>
  <tabular>
    <row>
      <cell><term>Part A:</term></cell>
    </row>
    <row>
      <cell><m>\frac{2}{3}</m> cup boiling water</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> cup oats</cell>
    </row>
    <row>
    <cell>2 tablespoons butter</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> cup white sugar</cell>
    </row>
    <row>
      <cell>2 cups rhubarb, diced</cell>
    </row>
    <row>
      <cell><term>Part B:</term></cell>
    </row>
    <row>
      <cell>1 cup flour</cell>
    </row>
    <row>
      <cell>1 teaspoon baking powder</cell>
    </row>
    <row>
      <cell><m>\frac{1}{4}</m> teaspoon baking soda</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> teaspoon cinnamon</cell>
    </row>
    <row>
      <cell><m>\frac{1}{4}</m> teaspoon salt</cell>
    </row>
    <row>
      <cell><term>Part C:</term></cell>
    </row>
    <row>
      <cell><m>\frac{2}{3}</m> cup sugar</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> cup brown sugar</cell>
    </row>
    <row>
      <cell><m>\frac{1}{4}</m> cup cooking oil</cell>
    </row>
    <row>
      <cell>1 egg</cell>
    </row>
  </tabular>

  <p>Instructions
    <ol>
      <li>
        <p>
          Melt butter in an 8" x 8" x 2" pan.
        </p>
      </li>
      <li>
        <p>
          Stir in the sugar from Part A, and sprinkle in rhubarb.
        </p>
      </li>
      <li>
        <p>
          Mix together the Part B ingredients, and set aside.
        </p>
      </li>
      <li>
        <p>
          Mix together the Part C ingredients.  Add water and oats.
        </p>
      </li>
      <li>
        <p>
          Add Part B ingredients to this mixture, and pour over the rhubarb mixture.
        </p>
      </li>
      <li>
        <p>
          Bake at <m>350^\circ</m> for 50 minutes.
        </p>
      </li>
    </ol>
  </p>

  <p>
    Notes:
    <ul>
      <li>
        <p>
          
        </p>
      </li>
    </ul>
  </p>
</section>