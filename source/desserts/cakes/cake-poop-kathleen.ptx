<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="poop" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Chocolate Upside-Down Pudding Cake (Aunt Kathleen)</title>

  <p>
    Ingredients:
  </p>
  <tabular>
    <row>
      <cell><term>Cake:</term></cell>
    </row>
    <row>
      <cell>1 cup flour</cell>
    </row>
    <row>
      <cell>1 tablespoon baking powder</cell>
    </row>
    <row>
    <cell><m>\frac{1}{4}</m> cup cocoa powder</cell>
    </row>
    <row>
      <cell><m>\frac{1}{4}</m> teaspoon salt</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> cup sugar</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}></m> cup butter</cell>
    </row>
    <row>
      <cell><m>\frac{1}{2}</m> cup milk</cell>
    </row>
    <row>
      <cell>1 teaspoon vanilla</cell>
    </row>
    <row>
      <cell><term>Sauce:</term></cell>
    </row>
    <row>
      <cell><m>\frac{3}{4}</m> cup sugar</cell>
    </row>
    <row>
      <cell><m>\frac{1}{4}</m> cup cocoa powder</cell>
    </row>
    <row>
      <cell>2 cups boiling water</cell>
    </row>
  </tabular>

  <p>Instructions
    <ol>
      <li>
        <p>
          Mix all cake ingredients together until <q>just mixed</q>. Spread in a lightly greased 8" x 8" pan.
        </p>
      </li>
      <li>
        <p>
          In a medium bowl, mix all sauce ingredients together, except the water.  Sprinkle evenly on top of the cake mixture.
        </p>
      </li>
      <li>
        <p>
          Carefully pour water over the top.  Do not mix.
        </p>
      </li>
      <li>
        <p>
          Bake at <m>350^\circ</m> for 40 minutes.
        </p>
      </li>
    </ol>
  </p>

  <p>
    Notes:
    <ul>
      <li>
        <p>
          
        </p>
      </li>
    </ul>
  </p>
</section>